{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "masterline",
  "version": "0.1.0",
  "identifier": "com.ajam.masterline",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "masterline",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' http://localhost:1420 https://api.coingecko.com https://api.binance.com; font-src 'self' data:; media-src 'self'; object-src 'self'; frame-src 'self';"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "ajam",
    "category": "Finance",
    "shortDescription": "Trading Dashboard",
    "longDescription": "Professional Trading Dashboard for managing accounts, trades, and investments.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:masterline.db"
      ]
    }
  }
}